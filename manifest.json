{
  "manifest_version": 3,
  "name": "AI Meeting Copilot",
  "version": "1.0.0",
  "description": "Real-time AI meeting intelligence — live summaries, topic tracking, decision detection, and private late-joiner briefings powered by OpenAI.",
  "permissions": [
    "activeTab",
    "storage",
    "sidePanel",
    "scripting",
    "tabCapture",
    "offscreen"
  ],
  "host_permissions": [
    "https://meet.google.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["meetingState.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon128.png",
      "48": "icons/icon128.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon128.png",
    "48": "icons/icon128.png",
    "128": "icons/icon128.png"
  },
  "side_panel": {
    "default_path": "dashboard.html"
  },
  "options_page": "options.html",
  "web_accessible_resources": [
    {
      "resources": ["offscreen.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
